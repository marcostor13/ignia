{
  "name": "ignia",
  "private": true,
  "version": "1.0.0",
  "description": "Angular + Python AI agents monorepo with token efficiency",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd apps/frontend && npm start",
    "dev:backend": "python -m uvicorn apps.backend.api.main:app --reload --port 8000",
    "build": "cd apps/frontend && npm run build",
    "install:all": "npm install && cd apps/frontend && npm install && pip install -r apps/backend/requirements.txt",
    "test:frontend": "cd apps/frontend && npm test",
    "lint": "cd apps/frontend && npx ng lint"
  },
  "dependencies": {
    "netlify-cli": "^26.0.2",
    "openai": "^4.0.0",
    "mongodb": "^6.0.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@types/nodemailer": "^6.4.0"
  }
}
