# ── WhatsApp Cloud API (Meta official) ──────────────────────────────────────
# Obtener en: https://developers.facebook.com/apps → tu app → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=          # Ej: 123456789012345
WHATSAPP_ACCESS_TOKEN=             # System User Token permanente de Meta Business
WHATSAPP_NOTIFY_PHONE=             # Teléfono del equipo Ignia con código país sin + (ej: 5491112345678)
WHATSAPP_COMMUNITY_URL=            # Link de invitación al grupo de WhatsApp (ej: https://chat.whatsapp.com/xxxx)
WHATSAPP_VERIFY_TOKEN=ignia_verify_2024   # Token que pones en Meta al configurar el webhook
WHATSAPP_WELCOME_TEMPLATE=ignia_bienvenida_taller  # Nombre del template aprobado en Meta

# ── Anthropic Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GOOGLE_API_KEY=AIza...

# Optional: override model defaults
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.0-flash

# ── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGOURI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ignia?retryWrites=true&w=majority

# ── Email — Outlook / Microsoft 365 ─────────────────────────────────────────
EMAIL_FROM=admin@ignia.site          # Cuenta de correo desde la que se envía
EMAIL_PASSWORD=                      # Contraseña o App Password (ver docs/EMAIL_SETUP.md)

# App settings
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8888
